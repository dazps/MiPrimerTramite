Obtener pasos de un trámite en orden (HU19, HU24).

SELECT titulo, descrip, orden 
FROM tramite_pasos 
WHERE id_tr = 1 
ORDER BY orden;


Ver checklist de progreso de un usuario en un trámite (HU24, HU25, HU26).

SELECT tp.titulo, utp.completado, utp.fechacompleta
FROM usuario_tramite_progreso utp
JOIN tramite_pasos tp ON utp.id_paso = tp.id_pa
WHERE utp.id_usuario = 5 AND utp.id_tramite = 1
ORDER BY tp.orden;
